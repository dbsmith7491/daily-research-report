# Copy this file to .env and fill in the values for your delivery channel.
# Only the variables for your chosen channel (set in config.yaml) are required.

# ── Kindle delivery ───────────────────────────────────────────────
# Uses Gmail SMTP to send report.html as an attachment to your Kindle email.
# Create a Gmail app password at: https://myaccount.google.com/apppasswords
KINDLE_GMAIL_USER=
KINDLE_GMAIL_APP_PASS=
KINDLE_EMAIL=

# ── Slack delivery ────────────────────────────────────────────────
# Posts report to a Slack channel via incoming webhook.
# Create a webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ── Notion delivery ───────────────────────────────────────────────
# Creates a new page in a Notion database with the report content.
# Create an integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Email delivery ────────────────────────────────────────────────
# Sends report.html as an inline HTML email via any SMTP server.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_TO=
